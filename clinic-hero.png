:root {
  --white: #ffffff;
  --ice: #f7fcff;
  --mist: #eaf7ff;
  --line: rgba(36, 114, 180, 0.16);
  --text: #0b2438;
  --muted: #517089;
  --blue: #0f7ee7;
  --blue-2: #46c7ff;
  --blue-3: #0b4c92;
  --cyan: #bff5ff;
  --silver: #d7e8f4;
  --shadow: 0 24px 80px rgba(16, 94, 158, 0.18);
  --soft-shadow: 0 16px 46px rgba(34, 119, 180, 0.14);
  --radius: 8px;
  --x: 50%;
  --y: 20%;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  overflow-x: hidden;
  color: var(--text);
  background:
    radial-gradient(circle at 20% 0%, rgba(98, 204, 255, 0.22), transparent 34rem),
    linear-gradient(180deg, #ffffff 0%, #f3fbff 42%, #ffffff 100%);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  letter-spacing: 0;
}

body::before {
  position: fixed;
  inset: 0;
  z-index: -3;
  pointer-events: none;
  content: "";
  background-image:
    linear-gradient(rgba(47, 154, 226, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(47, 154, 226, 0.05) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: linear-gradient(180deg, black, transparent 78%);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select {
  font: inherit;
}

button {
  cursor: pointer;
}

.cursor-light {
  position: fixed;
  inset: 0;
  z-index: 20;
  pointer-events: none;
  background: radial-gradient(circle at var(--x) var(--y), rgba(104, 215, 255, 0.22), transparent 18rem);
  mix-blend-mode: screen;
}

.site-shell {
  position: relative;
  isolation: isolate;
}

.topbar {
  position: fixed;
  top: 18px;
  left: 50%;
  z-index: 30;
  display: grid;
  width: min(1180px, calc(100% - 32px));
  min-height: 62px;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 24px;
  padding: 10px 12px 10px 18px;
  color: #07304f;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.78);
  border-radius: var(--radius);
  box-shadow: 0 18px 50px rgba(13, 84, 146, 0.14);
  backdrop-filter: blur(22px) saturate(1.25);
  transform: translateX(-50%);
}

.brand,
.nav-links,
.hero-actions,
.hero-metrics,
.treatment-switch,
.footer {
  display: flex;
  align-items: center;
}

.brand {
  gap: 10px;
  font-weight: 800;
}

.brand-mark {
  display: grid;
  width: 38px;
  height: 38px;
  place-items: center;
  color: white;
  background:
    radial-gradient(circle at 30% 20%, #ffffff 0 8%, transparent 9%),
    linear-gradient(135deg, #0065c9, #53d7ff);
  border-radius: 50%;
  box-shadow: 0 0 26px rgba(70, 199, 255, 0.55);
}

.nav-links {
  justify-content: center;
  gap: 6px;
}

.nav-links a,
.topbar-action {
  padding: 10px 12px;
  border-radius: 6px;
  color: #174563;
  font-size: 0.94rem;
  transition: background 180ms ease, color 180ms ease, transform 180ms ease;
}

.nav-links a:hover,
.topbar-action:hover {
  color: #003f85;
  background: rgba(209, 241, 255, 0.72);
  transform: translateY(-1px);
}

.topbar-action {
  color: white;
  background: linear-gradient(135deg, #0069d8, #3ecaff);
  box-shadow: 0 12px 30px rgba(20, 128, 218, 0.25);
}

.topbar-action:hover {
  color: white;
  background: linear-gradient(135deg, #005ebe, #21baf2);
}

.hero {
  position: relative;
  display: grid;
  min-height: 88svh;
  grid-template-columns: minmax(0, 1fr);
  align-items: center;
  overflow: hidden;
  padding: 126px max(24px, calc((100vw - 1180px) / 2)) 64px;
}

.hero-photo,
.hero-photo::after,
.hero-vignette,
#dental-stage,
.sparkle-field,
.fallback-3d {
  position: absolute;
  inset: 0;
}

.hero-photo {
  z-index: 0;
  background-image: url("assets/clinic-hero.png");
  background-position: center;
  background-size: cover;
  transform: scale(1.02);
}

.hero-photo::after {
  content: "";
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 255, 255, 0.82) 35%, rgba(246, 253, 255, 0.28) 66%, rgba(255, 255, 255, 0.34) 100%),
    radial-gradient(circle at 74% 36%, rgba(77, 201, 255, 0.35), transparent 22rem);
}

#dental-stage {
  z-index: 3;
  width: 100%;
  height: 100%;
}

html.three-ready .fallback-3d {
  opacity: 0;
}

.fallback-3d {
  z-index: 2;
  pointer-events: none;
  opacity: 1;
  transition: opacity 400ms ease;
}

.fallback-tooth {
  position: absolute;
  top: 26%;
  right: max(76px, calc((100vw - 1180px) / 2 + 120px));
  width: 330px;
  height: 330px;
  filter: drop-shadow(0 26px 55px rgba(18, 91, 146, 0.22));
  animation: float-tooth 5.8s ease-in-out infinite;
}

.fallback-tooth::before,
.fallback-tooth::after,
.fallback-tooth span {
  position: absolute;
  content: "";
  background:
    radial-gradient(circle at 34% 20%, rgba(255, 255, 255, 0.96), transparent 20%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(188, 234, 255, 0.62));
  border: 1px solid rgba(255, 255, 255, 0.92);
  box-shadow:
    inset -24px -30px 70px rgba(31, 143, 220, 0.16),
    0 0 80px rgba(78, 210, 255, 0.32);
}

.fallback-tooth::before {
  left: 28px;
  top: 18px;
  width: 150px;
  height: 168px;
  border-radius: 55% 45% 42% 58%;
}

.fallback-tooth::after {
  right: 28px;
  top: 18px;
  width: 150px;
  height: 168px;
  border-radius: 45% 55% 58% 42%;
}

.fallback-tooth span {
  left: 76px;
  top: 122px;
  width: 176px;
  height: 146px;
  border-radius: 44% 44% 58% 58%;
}

.fallback-tooth span::before,
.fallback-tooth span::after {
  position: absolute;
  top: 112px;
  width: 58px;
  height: 130px;
  content: "";
  background: linear-gradient(180deg, rgba(249, 254, 255, 0.88), rgba(188, 234, 255, 0.48));
  border: 1px solid rgba(255, 255, 255, 0.8);
  border-radius: 0 0 44% 44%;
}

.fallback-tooth span::before {
  left: 36px;
  transform: rotate(7deg);
}

.fallback-tooth span::after {
  right: 36px;
  transform: rotate(-7deg);
}

.fallback-orbit {
  position: absolute;
  top: 29%;
  right: max(20px, calc((100vw - 1180px) / 2 + 62px));
  width: 460px;
  height: 190px;
  border: 3px solid rgba(106, 226, 255, 0.28);
  border-radius: 50%;
  filter: drop-shadow(0 0 16px rgba(84, 213, 255, 0.42));
  animation: css-orbit 9s linear infinite;
}

.fallback-orbit-a {
  transform: rotate(-24deg);
}

.fallback-orbit-b {
  border-color: rgba(255, 255, 255, 0.6);
  transform: rotate(20deg);
  animation-duration: 7s;
}

.fallback-orbit-c {
  width: 400px;
  height: 150px;
  border-color: rgba(26, 137, 232, 0.24);
  transform: rotate(74deg);
  animation-duration: 11s;
}

.fallback-3d i {
  position: absolute;
  right: var(--right);
  top: var(--top);
  width: var(--size);
  height: var(--size);
  background: rgba(255, 255, 255, 0.7);
  transform: rotate(var(--rotate));
  box-shadow: 0 0 24px rgba(104, 218, 255, 0.45);
  animation: sparkle 4.8s ease-in-out infinite;
}

.fallback-3d i:nth-of-type(1) {
  --right: 9%;
  --top: 20%;
  --size: 38px;
  --rotate: 20deg;
}

.fallback-3d i:nth-of-type(2) {
  --right: 6%;
  --top: 42%;
  --size: 24px;
  --rotate: -18deg;
}

.fallback-3d i:nth-of-type(3) {
  --right: 18%;
  --top: 63%;
  --size: 28px;
  --rotate: 38deg;
}

.fallback-3d i:nth-of-type(4) {
  --right: 30%;
  --top: 26%;
  --size: 20px;
  --rotate: 14deg;
}

.fallback-3d i:nth-of-type(5) {
  --right: 3%;
  --top: 69%;
  --size: 46px;
  --rotate: -28deg;
}

.hero-vignette {
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 76% 28%, rgba(78, 211, 255, 0.34), transparent 24rem),
    radial-gradient(circle at 18% 66%, rgba(255, 255, 255, 0.92), transparent 34rem),
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(247, 252, 255, 0.96) 100%);
}

.sparkle-field {
  z-index: 4;
  pointer-events: none;
  overflow: hidden;
}

.sparkle-field span {
  position: absolute;
  left: var(--left);
  top: var(--top);
  width: var(--size);
  height: var(--size);
  border-radius: 50%;
  background: radial-gradient(circle, #ffffff 0 14%, rgba(160, 233, 255, 0.95) 22%, transparent 70%);
  filter: drop-shadow(0 0 10px rgba(70, 199, 255, 0.9));
  opacity: 0;
  transform: scale(0.4);
  animation: sparkle var(--duration) ease-in-out var(--delay) infinite;
}

.hero-content {
  position: relative;
  z-index: 5;
  width: min(620px, 100%);
}

.eyebrow {
  margin: 0 0 14px;
  color: #086bbd;
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 18px;
  color: #082a40;
  font-size: 5.5rem;
  line-height: 0.95;
}

h2 {
  margin-bottom: 18px;
  color: #0a2d46;
  font-size: 3.4rem;
  line-height: 1.02;
}

h3 {
  color: #0d3958;
  font-size: 1.25rem;
}

.hero-copy {
  width: min(560px, 100%);
  margin-bottom: 28px;
  color: #294f68;
  font-size: 1.22rem;
  line-height: 1.68;
}

.hero-actions {
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 34px;
}

.button {
  position: relative;
  display: inline-flex;
  min-height: 50px;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 0 20px;
  border: 1px solid transparent;
  border-radius: 6px;
  font-weight: 800;
  transform-style: preserve-3d;
  transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease, background 180ms ease;
}

.button::after {
  position: absolute;
  inset: -50% auto auto -30%;
  width: 58%;
  height: 200%;
  content: "";
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.68), transparent);
  transform: rotate(18deg) translateX(-130%);
}

.button:hover::after {
  animation: button-shine 820ms ease;
}

.button-primary {
  color: white;
  background: linear-gradient(135deg, #0064cf, #39c6ff);
  box-shadow: 0 18px 44px rgba(17, 126, 218, 0.3);
}

.button-secondary {
  color: #075b9d;
  background: rgba(255, 255, 255, 0.74);
  border-color: rgba(17, 126, 218, 0.22);
  box-shadow: 0 16px 40px rgba(41, 130, 196, 0.12);
  backdrop-filter: blur(16px);
}

.button:hover {
  transform: translateY(-2px);
}

.hero-metrics {
  flex-wrap: wrap;
  gap: 12px;
}

.hero-metrics div {
  width: 150px;
  min-height: 108px;
  padding: 16px;
  background: rgba(255, 255, 255, 0.64);
  border: 1px solid rgba(255, 255, 255, 0.84);
  border-radius: var(--radius);
  box-shadow: var(--soft-shadow);
  backdrop-filter: blur(18px);
}

.hero-metrics strong {
  display: block;
  color: #026cca;
  font-size: 2.1rem;
  line-height: 1;
}

.hero-metrics span {
  display: block;
  margin-top: 8px;
  color: #54728a;
  font-size: 0.9rem;
  line-height: 1.35;
}

.signal-panel {
  position: absolute;
  right: max(24px, calc((100vw - 1180px) / 2));
  bottom: 52px;
  z-index: 5;
  width: min(300px, calc(100% - 48px));
  min-height: 156px;
  padding: 20px;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(224, 248, 255, 0.62)),
    radial-gradient(circle at 80% 20%, rgba(65, 205, 255, 0.3), transparent 7rem);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  backdrop-filter: blur(22px);
}

.signal-panel p {
  margin-bottom: 8px;
  color: #4c7088;
}

.signal-panel strong {
  display: block;
  width: min(210px, 100%);
  color: #0b3f67;
  font-size: 1.25rem;
  line-height: 1.2;
}

.pulse-dot {
  display: inline-block;
  width: 10px;
  height: 10px;
  margin-right: 8px;
  background: #35d8ff;
  border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(53, 216, 255, 0.55);
  animation: pulse 1.8s ease-out infinite;
}

.mini-orbit {
  position: absolute;
  right: -20px;
  bottom: -20px;
  width: 142px;
  height: 142px;
  border: 1px solid rgba(55, 185, 250, 0.22);
  border-radius: 50%;
}

.mini-orbit span {
  position: absolute;
  inset: 22px;
  border: 1px solid rgba(30, 145, 231, 0.22);
  border-radius: 50%;
  animation: orbit 7s linear infinite;
}

.mini-orbit span:nth-child(2) {
  inset: 42px;
  animation-duration: 5s;
}

.mini-orbit span:nth-child(3) {
  inset: 62px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.95), rgba(73, 203, 255, 0.28));
  border: 0;
  box-shadow: 0 0 30px rgba(73, 203, 255, 0.6);
}

.trust-band,
.section,
.feature-lab,
.appointment {
  width: min(1180px, calc(100% - 48px));
  margin-inline: auto;
}

.trust-band {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  margin-top: 18px;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--line);
  box-shadow: var(--soft-shadow);
}

.trust-item {
  min-height: 194px;
  padding: 26px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.93), rgba(239, 250, 255, 0.9)),
    radial-gradient(circle at 90% 12%, rgba(82, 205, 255, 0.18), transparent 10rem);
}

.trust-item span {
  display: block;
  margin-bottom: 20px;
  color: #0082df;
  font-weight: 900;
}

.trust-item strong {
  display: block;
  margin-bottom: 10px;
  font-size: 1.22rem;
}

.trust-item p,
.section-heading p,
.feature-copy p,
.timeline-step p,
.appointment-copy p,
.service-card p,
.holo-panel p,
.footer {
  color: var(--muted);
  line-height: 1.65;
}

.section {
  padding: 108px 0 40px;
}

.section-heading {
  width: min(700px, 100%);
  margin-bottom: 34px;
}

.treatment-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.service-card {
  position: relative;
  min-height: 306px;
  padding: 24px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(236, 249, 255, 0.92)),
    radial-gradient(circle at 72% 16%, rgba(73, 203, 255, 0.24), transparent 10rem);
  border: 1px solid rgba(36, 114, 180, 0.14);
  border-radius: var(--radius);
  box-shadow: var(--soft-shadow);
  transform-style: preserve-3d;
  transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
}

.service-card::before {
  position: absolute;
  inset: 0;
  content: "";
  opacity: 0;
  background: radial-gradient(circle at var(--card-x, 50%) var(--card-y, 20%), rgba(255, 255, 255, 0.9), transparent 8rem);
  transition: opacity 180ms ease;
}

.service-card:hover {
  border-color: rgba(22, 150, 237, 0.3);
  box-shadow: 0 28px 70px rgba(22, 117, 190, 0.18);
}

.service-card:hover::before {
  opacity: 1;
}

.service-card > * {
  position: relative;
  z-index: 1;
}

.service-icon {
  display: grid;
  width: 54px;
  height: 54px;
  margin-bottom: 64px;
  place-items: center;
  color: #0274d5;
  background: linear-gradient(135deg, #ffffff, #dff7ff);
  border: 1px solid rgba(24, 142, 224, 0.16);
  border-radius: 50%;
  box-shadow: 0 0 34px rgba(58, 200, 255, 0.32);
  font-size: 1.4rem;
  font-weight: 900;
}

.service-card h3 {
  margin-bottom: 12px;
}

.feature-lab {
  display: grid;
  grid-template-columns: 0.92fr 1.08fr;
  align-items: center;
  gap: 42px;
  margin-top: 70px;
  padding: 54px;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(225, 247, 255, 0.86)),
    radial-gradient(circle at 82% 26%, rgba(58, 200, 255, 0.24), transparent 22rem);
  border: 1px solid rgba(36, 114, 180, 0.14);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.feature-copy p {
  font-size: 1.04rem;
}

.treatment-switch {
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 28px;
}

.switch-button {
  min-height: 42px;
  padding: 0 14px;
  color: #17628f;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(18, 121, 213, 0.14);
  border-radius: 6px;
  transition: transform 180ms ease, background 180ms ease, color 180ms ease;
}

.switch-button:hover,
.switch-button.is-active {
  color: white;
  background: linear-gradient(135deg, #026dd2, #42c9ff);
  transform: translateY(-1px);
}

.holo-panel {
  position: relative;
  min-height: 430px;
  overflow: hidden;
  padding: 32px;
  background:
    radial-gradient(circle at 50% 40%, rgba(255, 255, 255, 0.86), rgba(214, 245, 255, 0.5) 36%, rgba(255, 255, 255, 0.75) 70%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(234, 248, 255, 0.78));
  border: 1px solid rgba(255, 255, 255, 0.92);
  border-radius: var(--radius);
  box-shadow: inset 0 1px 0 white, var(--soft-shadow);
}

.scan-grid {
  position: absolute;
  inset: 0;
  opacity: 0.38;
  background-image:
    linear-gradient(rgba(20, 132, 224, 0.16) 1px, transparent 1px),
    linear-gradient(90deg, rgba(20, 132, 224, 0.16) 1px, transparent 1px);
  background-size: 38px 38px;
  transform: perspective(700px) rotateX(60deg) translateY(88px) scale(1.3);
  transform-origin: center bottom;
  animation: grid-drift 9s linear infinite;
}

.holo-tooth {
  position: absolute;
  top: 58px;
  left: 50%;
  width: 180px;
  height: 230px;
  border-radius: 52% 48% 44% 46% / 46% 46% 58% 58%;
  background:
    radial-gradient(circle at 38% 22%, rgba(255, 255, 255, 0.96), transparent 20%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(166, 225, 255, 0.44));
  border: 1px solid rgba(255, 255, 255, 0.95);
  box-shadow:
    inset -24px -26px 60px rgba(19, 133, 213, 0.18),
    0 0 80px rgba(56, 205, 255, 0.46);
  transform: translateX(-50%);
  animation: float-tooth 5.8s ease-in-out infinite;
}

.holo-tooth::before,
.holo-tooth::after {
  position: absolute;
  bottom: -58px;
  width: 58px;
  height: 112px;
  content: "";
  background: linear-gradient(180deg, rgba(247, 253, 255, 0.8), rgba(177, 230, 255, 0.42));
  border-radius: 0 0 46% 46%;
}

.holo-tooth::before {
  left: 44px;
  transform: rotate(8deg);
}

.holo-tooth::after {
  right: 44px;
  transform: rotate(-8deg);
}

.holo-tooth span {
  position: absolute;
  inset: -22px;
  border: 1px solid rgba(44, 188, 255, 0.3);
  border-radius: 50%;
  transform: rotateX(68deg);
  animation: orbit 6s linear infinite;
}

.holo-panel h3,
.holo-panel p {
  position: relative;
  z-index: 1;
  width: min(360px, 100%);
}

.holo-panel h3 {
  margin-top: 312px;
}

.experience {
  padding-top: 112px;
}

.timeline {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.timeline::before {
  position: absolute;
  top: 28px;
  right: 8%;
  left: 8%;
  height: 1px;
  content: "";
  background: linear-gradient(90deg, transparent, rgba(33, 150, 226, 0.52), transparent);
}

.timeline-step {
  position: relative;
  min-height: 260px;
  padding: 74px 20px 22px;
  background: rgba(255, 255, 255, 0.76);
  border: 1px solid rgba(31, 132, 208, 0.14);
  border-radius: var(--radius);
  box-shadow: 0 12px 36px rgba(33, 121, 184, 0.1);
}

.timeline-step::before {
  position: absolute;
  top: 21px;
  left: 20px;
  width: 14px;
  height: 14px;
  content: "";
  background: #ffffff;
  border: 4px solid #35c7ff;
  border-radius: 50%;
  box-shadow: 0 0 24px rgba(53, 199, 255, 0.8);
}

.timeline-step span {
  display: block;
  margin-bottom: 14px;
  color: #0871c5;
  font-size: 0.88rem;
  font-weight: 900;
}

.timeline-step strong {
  display: block;
  margin-bottom: 10px;
  color: #0b3656;
  font-size: 1.12rem;
}

.appointment {
  display: grid;
  grid-template-columns: 0.88fr 1.12fr;
  gap: 34px;
  align-items: start;
  margin-top: 72px;
  margin-bottom: 56px;
  padding: 48px;
  background:
    linear-gradient(135deg, rgba(8, 92, 168, 0.95), rgba(31, 188, 247, 0.84)),
    radial-gradient(circle at 80% 14%, rgba(255, 255, 255, 0.45), transparent 15rem);
  border-radius: var(--radius);
  box-shadow: 0 30px 90px rgba(4, 81, 148, 0.22);
}

.appointment .eyebrow,
.appointment h2,
.appointment-copy p {
  color: white;
}

.appointment-copy p {
  opacity: 0.86;
}

.booking-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  padding: 18px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.78);
  border-radius: var(--radius);
  box-shadow: 0 20px 60px rgba(4, 64, 124, 0.2);
}

.booking-form label {
  display: grid;
  gap: 8px;
  color: #194b68;
  font-weight: 800;
}

.booking-form label:first-child,
.booking-form label:nth-child(4),
.booking-form .form-result,
.booking-form button {
  grid-column: 1 / -1;
}

.booking-form input,
.booking-form select {
  width: 100%;
  min-height: 48px;
  padding: 0 12px;
  color: #0b314d;
  background: #ffffff;
  border: 1px solid rgba(27, 127, 210, 0.18);
  border-radius: 6px;
  outline: none;
  transition: border-color 160ms ease, box-shadow 160ms ease;
}

.booking-form input:focus,
.booking-form select:focus {
  border-color: rgba(0, 119, 214, 0.58);
  box-shadow: 0 0 0 4px rgba(66, 201, 255, 0.18);
}

.booking-form input[type="range"] {
  padding: 0;
  accent-color: #0878dc;
}

.range-readout {
  color: #0871c5;
  font-size: 0.92rem;
}

.form-result {
  min-height: 70px;
  padding: 16px;
  color: #0b4c78;
  background: linear-gradient(135deg, rgba(228, 248, 255, 0.86), rgba(255, 255, 255, 0.94));
  border: 1px solid rgba(21, 132, 218, 0.15);
  border-radius: 6px;
  line-height: 1.5;
}

.footer {
  justify-content: space-between;
  width: min(1180px, calc(100% - 48px));
  margin: 0 auto 34px;
  padding-top: 20px;
  border-top: 1px solid rgba(36, 114, 180, 0.12);
}

html.js .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 700ms ease, transform 700ms ease;
}

html.js .reveal.is-visible,
html.no-js .reveal {
  opacity: 1;
  transform: translateY(0);
}

@keyframes sparkle {
  0%,
  100% {
    opacity: 0;
    transform: scale(0.25) rotate(0deg);
  }

  40% {
    opacity: 0.95;
    transform: scale(1) rotate(120deg);
  }

  60% {
    opacity: 0.58;
    transform: scale(0.62) rotate(180deg);
  }
}

@keyframes button-shine {
  to {
    transform: rotate(18deg) translateX(340%);
  }
}

@keyframes pulse {
  70% {
    box-shadow: 0 0 0 18px rgba(53, 216, 255, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(53, 216, 255, 0);
  }
}

@keyframes orbit {
  to {
    transform: rotate(360deg);
  }
}

@keyframes grid-drift {
  to {
    background-position: 0 38px, 38px 0;
  }
}

@keyframes float-tooth {
  0%,
  100% {
    transform: translateX(-50%) translateY(0) rotate(-2deg);
  }

  50% {
    transform: translateX(-50%) translateY(-18px) rotate(2deg);
  }
}

@keyframes css-orbit {
  0% {
    rotate: 0deg;
  }

  100% {
    rotate: 360deg;
  }
}

@media (max-width: 980px) {
  .topbar {
    grid-template-columns: 1fr auto;
  }

  .nav-links {
    display: none;
  }

  .hero {
    min-height: 88svh;
    padding-top: 118px;
  }

  h1 {
    font-size: 4rem;
  }

  h2 {
    font-size: 2.55rem;
  }

  .signal-panel {
    position: relative;
    right: auto;
    bottom: auto;
    width: min(360px, 100%);
    margin-top: 28px;
  }

  .trust-band,
  .feature-lab,
  .appointment {
    grid-template-columns: 1fr;
  }

  .treatment-grid,
  .timeline {
    grid-template-columns: repeat(2, 1fr);
  }

  .feature-lab,
  .appointment {
    padding: 32px;
  }
}

@media (max-width: 640px) {
  .topbar {
    top: 10px;
    width: calc(100% - 20px);
    min-height: 58px;
    padding-left: 12px;
    gap: 10px;
  }

  .brand span:last-child {
    max-width: 110px;
  }

  .topbar-action {
    padding-inline: 10px;
  }

  .hero {
    min-height: 86svh;
    padding: 96px 20px 24px;
  }

  .hero-photo {
    background-position: 61% center;
  }

  .fallback-tooth {
    top: 38%;
    right: -100px;
    width: 260px;
    height: 260px;
    opacity: 0.72;
  }

  .fallback-orbit {
    top: 44%;
    right: -120px;
    width: 310px;
    height: 124px;
    opacity: 0.62;
  }

  .hero-photo::after {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 255, 255, 0.83) 58%, rgba(255, 255, 255, 0.66) 100%),
      radial-gradient(circle at 68% 18%, rgba(77, 201, 255, 0.28), transparent 14rem);
  }

  h1 {
    font-size: 2.85rem;
  }

  h2 {
    font-size: 2.1rem;
  }

  .hero-copy {
    font-size: 1rem;
    line-height: 1.5;
    margin-bottom: 18px;
  }

  .hero-actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    width: min(238px, 100%);
    margin-bottom: 18px;
  }

  .hero-metrics div {
    width: calc(33.333% - 8px);
    min-height: 94px;
    padding: 13px;
  }

  .hero-metrics strong {
    font-size: 1.7rem;
  }

  .hero-metrics span {
    font-size: 0.78rem;
  }

  .signal-panel {
    display: none;
  }

  .trust-band,
  .treatment-grid,
  .timeline,
  .booking-form {
    grid-template-columns: 1fr;
  }

  .trust-band,
  .section,
  .feature-lab,
  .appointment,
  .footer {
    width: calc(100% - 32px);
  }

  .section {
    padding-top: 76px;
  }

  .feature-lab,
  .appointment {
    padding: 22px;
  }

  .holo-panel {
    min-height: 386px;
    padding: 24px;
  }

  .holo-tooth {
    top: 46px;
    width: 144px;
    height: 184px;
  }

  .holo-panel h3 {
    margin-top: 254px;
  }

  .timeline::before {
    display: none;
  }

  .footer {
    display: grid;
    gap: 8px;
  }
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  *,
  *::before,
  *::after {
    animation-duration: 1ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 1ms !important;
  }

  #dental-stage,
  .cursor-light {
    display: none;
  }
}
